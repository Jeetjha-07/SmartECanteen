# MongoDB Connection String
# Replace with your MongoDB Atlas connection string
MONGODB_URI="mongodb+srv://username:password@cluster.mongodb.net/smartcanteen?retryWrites=true&w=majority"

# JWT Secret Key for authentication
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="generate-with-the-command-above"

# Server Port
PORT=3000

# Environment (development/production)
NODE_ENV=production

# Cloudinary Image Storage Configuration
# Get from: https://cloudinary.com/console/
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# Razorpay Payment Gateway Configuration
# Get from: https://dashboard.razorpay.com/app/keys
# For TESTING: Use test keys (rzp_test_...)
# For PRODUCTION: Use live keys (rzp_live_...)
RAZORPAY_KEY_ID="rzp_test_your_key_id_here"
RAZORPAY_KEY_SECRET="your_razorpay_key_secret_here"
